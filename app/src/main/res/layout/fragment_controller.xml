<?xml version="1.0" encoding="utf-8"?>
<!-- [CONTROLLER MODE — TEMPORARY, REMOVABLE] -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <!-- Stop button — PINNED at bottom -->
    <Button
        android:id="@+id/btnStop"
        style="@style/Widget.WifiScanner.Button.Danger"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="⏹ Стоп"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Scrollable content above Stop -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btnStop"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginBottom="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Header: timer + count -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/tvControllerTimer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⏱ 00:00:00"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"/>

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"/>

                <TextView
                    android:id="@+id/tvCheckpointCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 чекпоинтов"
                    android:textSize="13sp"
                    android:textColor="?android:attr/textColorSecondary"/>
            </LinearLayout>

            <!-- Current position — dark text on light green -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardElevation="2dp"
                app:cardCornerRadius="8dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="#E8F5E9">

                <TextView
                    android:id="@+id/tvCurrentLocation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:text="📍 Текущий: —"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1B5E20"/>
            </com.google.android.material.card.MaterialCardView>

            <!-- УЛИЦА -->
            <Button
                android:id="@+id/btnStreet"
                style="@style/Widget.WifiScanner.Button"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="🚶 Улица"
                android:backgroundTint="#FF5722"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="8dp"/>

            <!-- Address selector label -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Адрес"
                style="@style/TextAppearance.WifiScanner.Breadcrumbs"
                android:layout_marginBottom="4dp"/>

            <!-- Address selector -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:id="@+id/llAddressSelector"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"/>
            </HorizontalScrollView>

            <!-- Entrance label -->
            <TextView
                android:id="@+id/tvEntranceLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Подъезд"
                style="@style/TextAppearance.WifiScanner.Breadcrumbs"
                android:layout_marginBottom="4dp"
                android:visibility="gone"/>

            <!-- Entrance selector -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:id="@+id/llEntranceSelector"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"/>
            </HorizontalScrollView>

            <!-- ПЕРЕД ПОДЪЕЗДОМ -->
            <Button
                android:id="@+id/btnBeforeEntrance"
                style="@style/Widget.WifiScanner.Button"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="🚪 Перед подъездом"
                android:backgroundTint="#795548"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="8dp"
                android:visibility="gone"/>

            <!-- Floor grid -->
            <LinearLayout
                android:id="@+id/llFloorGrid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="8dp"/>

            <!-- ЛИФТ -->
            <Button
                android:id="@+id/btnElevator"
                style="@style/Widget.WifiScanner.Button"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="🛗 Лифт"
                android:backgroundTint="#607D8B"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="12dp"
                android:visibility="gone"/>

            <!-- Log divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?android:attr/listDivider"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Лог чекпоинтов"
                style="@style/TextAppearance.WifiScanner.Breadcrumbs"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:lineSpacingExtra="2dp"
                android:minHeight="60dp"/>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
