<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Базовый стиль для больших кнопок-действий (56dp) -->
    <style name="Widget.WifiScanner.Button" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_height">56dp</item>
        <item name="android:textSize">16sp</item>
        <item name="textAllCaps">false</item>
        <item name="cornerRadius">8dp</item>
    </style>

    <!-- Стиль для кнопки Отмена -->
    <style name="Widget.WifiScanner.Button.Danger" parent="Widget.WifiScanner.Button">
        <item name="backgroundTint">#d32f2f</item>
        <item name="android:textColor">#ffffff</item>
    </style>

    <!-- Стиль для текста вкладок (единый размер) -->
    <style name="TextAppearance.WifiScanner.Tab" parent="TextAppearance.Design.Tab">
        <item name="android:textSize">14sp</item>
        <item name="textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
    </style>
    
    <!-- Стиль для Хлебных крошек и статусов "Ожидает" -->
    <style name="TextAppearance.WifiScanner.Breadcrumbs" parent="TextAppearance.AppCompat.Body2">
        <item name="android:textColor">?android:attr/textColorSecondary</item>
        <item name="android:textSize">14sp</item>
    </style>
</resources>
